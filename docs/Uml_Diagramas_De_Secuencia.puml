' ══════════════════════════════════════
' SECUENCIA 3 — SEGUIMIENTO DE PEDIDO
' ══════════════════════════════════════

title Secuencia — Seguimiento de Pedido

skinparam sequenceArrowColor #555555
skinparam sequenceLifeLineBorderColor #111111
skinparam sequenceParticipantBackgroundColor #F5F5F3
skinparam sequenceParticipantBorderColor #111111
skinparam defaultFontName Helvetica
skinparam noteBorderColor #DDDDDD
skinparam noteBackgroundColor #FFFFFF

title Secuencia — Seguimiento de Pedido

actor "Cliente" as C
actor "Administrador" as A
participant "React\n(Frontend)" as FE
participant "Express\n(Backend)" as BE
database "MySQL\n(BD)" as DB
participant "Nodemailer" as NM

== Cliente consulta su pedido ==

C -> FE : Entra a Perfil\n/ Mis Pedidos
FE -> BE : GET /api/pedidos/mis-pedidos
BE -> DB : SELECT * FROM pedidos\nWHERE usuarioId = ?
DB --> BE : Lista de pedidos
BE --> FE : 200 — Pedidos del usuario
FE --> C : Muestra historial\nde compras

C -> FE : Selecciona un pedido
FE -> BE : GET /api/pedidos/:id/estado
BE -> DB : SELECT * FROM historial_envio\nWHERE pedidoId = ?
DB --> BE : Historial de estados
BE --> FE : 200 — Estados + fechas
FE --> C : Muestra línea de tiempo\ndel pedido

== Administrador actualiza el estado ==

A -> FE : Entra al panel\nde pedidos
FE -> BE : GET /api/admin/pedidos
BE -> DB : SELECT * FROM pedidos
DB --> BE : Lista completa de pedidos
BE --> FE : 200 — Todos los pedidos
FE --> A : Muestra lista\ncon filtros

A -> FE : Selecciona pedido\ny cambia estado
FE -> BE : PATCH /api/admin/pedidos/:id/estado\n(nuevoEstado)
BE -> DB : UPDATE pedidos\nSET estado = nuevoEstado
BE -> DB : INSERT INTO historial_envio\n(estado, fecha)
DB --> BE : Cambio confirmado
BE -> NM : Enviar correo\nde notificación al cliente
NM --> C : Correo — Estado actualizado
BE --> FE : 200 — Estado actualizado
FE --> A : Mensaje de éxito



@enduml